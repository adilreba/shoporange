{
  "name": "atushome-backend",
  "version": "1.0.0",
  "description": "AtusHome E-Commerce Backend - AWS SDK v3",
  "main": "index.js",
  "scripts": {
    "compile": "tsc",
    "copy-deps": "./scripts/copy-deps.sh",
    "build": "tsc && ./scripts/copy-deps.sh && sam build",
    "deploy": "sam deploy --guided",
    "local": "sam local start-api",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-apigatewaymanagementapi": "^3.1016.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.1021.0",
    "@aws-sdk/client-dynamodb": "^3.450.0",
    "@aws-sdk/client-kms": "^3.450.0",
    "@aws-sdk/client-s3": "^3.450.0",
    "@aws-sdk/client-secrets-manager": "^3.1025.0",
    "@aws-sdk/client-ses": "^3.450.0",
    "@aws-sdk/client-sns": "^3.450.0",
    "@aws-sdk/lib-dynamodb": "^3.450.0",
    "@aws-sdk/s3-request-presigner": "^3.450.0",
    "@opensearch-project/opensearch": "^3.5.1",
    "bcrypt": "^6.0.0",
    "fast-xml-parser": "^5.5.10",
    "iyzipay": "^2.0.67",
    "pdf-lib": "^1.17.1",
    "redis": "^5.12.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.131",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20.11.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
