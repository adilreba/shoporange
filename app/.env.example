# AWS API Configuration
# Replace with your actual API Gateway URL after deployment
# NOT: Region ile samconfig.toml'daki region AYNI olmalidir (eu-west-1)
VITE_API_URL=https://your-api-gateway-url.execute-api.eu-west-1.amazonaws.com/prod

# AWS Region
VITE_AWS_REGION=eu-west-1

# Stripe Configuration
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key

# Social Login Configuration
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_FACEBOOK_APP_ID=your-facebook-app-id

# Application Configuration
VITE_APP_NAME=AtusHome
VITE_APP_URL=https://your-domain.com

# =============================================================================
# ANALYTICS & TRACKING
# =============================================================================
# Google Analytics 4 (GA4) Measurement ID
# Al: https://analytics.google.com → Admin → Data Streams → Web
VITE_GA_ID=G-XXXXXXXXXX

# Google Tag Manager Container ID
# Al: https://tagmanager.google.com
VITE_GTM_ID=GTM-XXXXXX

# Facebook Pixel ID
# Al: https://business.facebook.com/events_manager
VITE_FB_PIXEL_ID=XXXXXXXXXX

# Hotjar Site ID
# Al: https://insights.hotjar.com
VITE_HOTJAR_ID=XXXXXX

# Hotjar Snippet Version (varsayılan: 6)
VITE_HOTJAR_SV=6

# Microsoft Clarity Project ID
# Al: https://clarity.microsoft.com
VITE_CLARITY_ID=XXXXXXXXXX

# =============================================================================
# GROWTHBOOK A/B TESTING
# =============================================================================
# GrowthBook Client Key (Cloud hosted)
# Al: https://app.growthbook.io → SDK Configuration
VITE_GROWTHBOOK_CLIENT_KEY=sdk-XXXXXXXXXX

# GrowthBook API Host (varsayılan: GrowthBook Cloud)
# Self-hosted kullanıyorsanız kendi domain'inizi yazın
VITE_GROWTHBOOK_API_HOST=https://cdn.growthbook.io

# GrowthBook Decryption Key (opsiyonel — encrypted payload için)
VITE_GROWTHBOOK_DECRYPTION_KEY=
